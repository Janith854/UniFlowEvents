# UniFlowEvents Frontend — Environment Template
# Copy this file to .env and fill in real values.
# NEVER commit .env or .env.local to source control.

# Backend API base URL
VITE_API_BASE_URL=http://localhost:5002/api

# Stripe publishable key (get from https://dashboard.stripe.com/apikeys)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_WITH_YOUR_STRIPE_PUBLISHABLE_KEY
